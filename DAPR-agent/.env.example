# DAPR-Agent 环境变量配置
# 复制本文件为 .env 并填入实际值

# ── Kimi API (Moonshot) ──
# 从 https://www.moonshot.cn/ 控制台获取
MOONSHOT_API_KEY=your-moonshot-api-key-here

# ── 本地数据加密 ──
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DAPR_ENCRYPTION_KEY=your-32-byte-base64-key-here=

# ── 本地 VLM 开关 ──
# true: 使用本地 Qwen3.5 (图像/视频不上云端)
# false: 全部走云端 Kimi (开发调试时用)
USE_LOCAL_VLM=true
